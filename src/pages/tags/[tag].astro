---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const tagSet = new Set<string>();
  posts
    .filter((p) => !p.data.draft)
    .forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
  return Array.from(tagSet).map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter((p) => !p.data.draft && p.data.tags.includes(tag!))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title={`标签: ${tag}`}>
  <h1>标签: {tag}</h1>
  <div class="post-list" style="margin-top:1.5rem">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
  <p style="margin-top:1.5rem;color:var(--text-muted)">
    <a href="/">← 返回文章列表</a>
  </p>
</Layout>
